local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local UserInputService = game:GetService('UserInputService')
local CurrentCamera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

--// Config
local Config = {
    -- Master Toggles
    MasterLock = false,
    MasterSpeed = false,

    -- State
    LockActive = false,
    SpeedActive = false,

    -- Keybinds
    MouseLockKey = Enum.KeyCode.X,
    WalkSpeedKey = Enum.KeyCode.J,
    ToggleGUIKey = Enum.KeyCode.Insert,
    
    -- Activation Settings
    UseRightClick = false, 
    ActivationType = "Toggle", 
    
    -- Parameters
    Smoothness = 0.71,
    Prediction = 0.250,
    LeftOffset = 2.34,
    UpOffset = -10.53,
    HitPart = 'HumanoidRootPart',
    WalkSpeedValue = 100,
}

--// GUI Setup
local ImGui = loadstring(game:HttpGet('https://github.com/depthso/Roblox-ImGUI/raw/main/ImGui.lua'))()

local Window = ImGui:CreateWindow({
    Title = 'T5INTED FLAMELOCK XOXO',
    Size = UDim2.fromOffset(400, 480),
    Position = UDim2.fromScale(0.5, 0.2),
})

--// Main Flamelock Tab
local MouseTab = Window:CreateTab({ Name = 'flamelock' })

MouseTab:Checkbox({
    Label = 'Enable Flamelock Master ✨',
    Value = Config.MasterLock,
    Callback = function(_, v) 
        Config.MasterLock = v 
        Config.LockActive = false 
    end,
})

MouseTab:Checkbox({
    Label = 'Use Right Mouse Button 🖱️',
    Value = Config.UseRightClick,
    Callback = function(_, v) Config.UseRightClick = v end,
})

MouseTab:Combo({
    Label = 'Activation Type',
    Items = {"Toggle", "Hold"},
    Value = Config.ActivationType,
    Callback = function(_, v) 
        Config.ActivationType = v 
        Config.LockActive = false 
    end,
})

MouseTab:Slider({
    Label = 'Smoothness', MinValue = 0, MaxValue = 1,
    Value = Config.Smoothness, Callback = function(_, v) Config.Smoothness = v end,
})

--// Movement Tab
local MoveTab = Window:CreateTab({ Name = 'movement' })
MoveTab:Checkbox({
    Label = 'Enable Speed Master 🏃‍♀️',
    Value = Config.MasterSpeed,
    Callback = function(_, v) 
        Config.MasterSpeed = v 
        Config.SpeedActive = false 
    end,
})
MoveTab:Slider({
    Label = 'Speed Value', MinValue = 16, MaxValue = 500,
